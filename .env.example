# Copy to .env.local and fill in real values — never commit .env.local

# Client-side (exposed to browser via Vite)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-side only (Vercel function env vars — NOT prefixed with VITE_)
# SUPABASE_URL duplicates the URL above because Vercel functions can't read VITE_ vars in prod
SUPABASE_URL=https://your-project.supabase.co
# Found in Supabase dashboard → Project Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Set to true to serve data/seed.json instead of hitting the live Lucee endpoint
USE_STATIC_SEED=true
# Phase 4 only — leave blank until the real endpoint exists
ROSTER_API_URL=
ROSTER_API_KEY=
